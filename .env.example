# Knowledge Hub environment configuration
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file.

# Database
POSTGRES_DB=knowledgehub
POSTGRES_USER=kh_user
POSTGRES_PASSWORD=kh_dev_secret
DATABASE_URL=jdbc:postgresql://localhost:5433/knowledgehub

# MinIO Object Storage
MINIO_ROOT_USER=kh_admin
MINIO_ROOT_PASSWORD=kh_dev_minio_secret
# Use a prefix-restricted application key outside local development.
MINIO_ACCESS_KEY=kh_admin
MINIO_SECRET_KEY=kh_dev_minio_secret
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET_PREFIX=kh-user
STORAGE_TYPE=minio
STORAGE_DOWNLOAD_URL_TTL=5m
STORAGE_ORPHAN_CLEANUP_DELAY=15m
STORAGE_CLEANUP_POLL_DELAY=1m

# JWT
JWT_ISSUER=knowledge-hub
JWT_AUDIENCE=knowledge-hub-api
# Use at least 32 random bytes outside development.
JWT_SECRET=change-this-development-secret-32-bytes
JWT_ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# App
APP_BASE_URL=http://localhost:8080
APP_WEB_URL=http://localhost:5173
# Vite reads this value when the frontend dev server starts.
VITE_API_URL=http://localhost:8080
RESET_TOKEN_TTL=15m
UPLOAD_CONFIRMATION_TOKEN_TTL=15m
UPLOAD_CONFIRMATION_TOKEN_CLEANUP_DELAY=1h
REGISTRATION_ENABLED=true
AUTH_SECURE_COOKIES=false
AUTH_RATE_LIMIT_MAX_ATTEMPTS=20
AUTH_RATE_LIMIT_WINDOW=1m
AUTH_LOG_RESET_TOKENS=true
ACCOUNT_DELETION_INITIAL_DELAY=30s
ACCOUNT_DELETION_POLL_DELAY=30s
INGESTION_INITIAL_DELAY=30s
INGESTION_POLL_DELAY=5s
INGESTION_LEASE_DURATION=5m
INGESTION_MAX_RETRIES=5
INGESTION_RETRY_DELAY=1m

# SMTP (optional in dev; leave blank to log instead of send)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173

# OpenRouter / OpenAI-compatible provider
AI_PROVIDER_BASE_URL=https://openrouter.ai/api/v1
# Required when AI_FAKE_MODE=false. Keep the real value only in .env or a secret store.
AI_PROVIDER_API_KEY=
AI_CHAT_MODEL=google/gemini-2.5-flash-lite
AI_EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free
AI_EMBEDDING_DIMENSION=1024

# Limits
LIMIT_UPLOAD_MAX_SIZE_BYTES=52428800
LIMIT_UPLOAD_MAX_FILES_PER_BATCH=20
HTTP_MULTIPART_MAX_FILE_SIZE=100MB
HTTP_MULTIPART_MAX_REQUEST_SIZE=500MB
LIMIT_EXTRACTED_CHARACTER_COUNT=100000
LIMIT_CHUNK_COUNT=500
LIMIT_CHUNK_SIZE=1000
LIMIT_CHUNK_OVERLAP=200
LIMIT_RETRIEVED_CHUNK_COUNT=10
LIMIT_SEARCH_QUERY_CHARACTERS=500
SEARCH_MINIMUM_SEMANTIC_SCORE=0.1
LIMIT_CHAT_MESSAGE_CHARACTERS=4000
LIMIT_CHAT_SCOPE_DOCUMENTS=50
LIMIT_CHAT_HISTORY_MESSAGES=12
CHAT_MINIMUM_KEYWORD_SCORE=0.01
CHAT_MINIMUM_SEMANTIC_SCORE=0.7
CHAT_STREAM_TIMEOUT=2m
LIMIT_CHAT_TOKEN_BUDGET=4096

# Fake AI mode (true = deterministic fake clients, no real API calls)
AI_FAKE_MODE=true

# API documentation and structured logging
# Production profile disables OpenAPI regardless of this development default.
OPENAPI_ENABLED=true
LOG_STRUCTURED_FORMAT=ecs
